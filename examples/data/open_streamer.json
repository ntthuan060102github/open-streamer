{
  "streams": {
    "obs-passthrough": {
      "code": "obs-passthrough",
      "name": "OBS Push \u2014 Passthrough (no transcoding)",
      "description": "OBS or any RTMP encoder pushes to :1935. Stream is forwarded as-is to HLS and DASH.",
      "inputs": [
        {
          "url": "rtmp://0.0.0.0:1935/live/obs-passthrough",
          "priority": 0,
          "net": {
            "reconnect": true,
            "reconnect_delay_sec": 2,
            "reconnect_max_delay_sec": 30
          }
        }
      ],
      "protocols": {
        "hls": true,
        "dash": true,
        "rtsp": false,
        "rtmp": false,
        "srt": false
      },
      "status": "stopped",
      "disabled": false
    },
    "rtmp-abr": {
      "code": "rtmp-abr",
      "name": "RTMP Pull \u2014 ABR Transcoding (3 profiles)",
      "description": "Pulls from a remote RTMP source. Transcodes to FHD/HD/SD ABR ladder with NVENC. Serves HLS, DASH, RTSP, and RTMP play. DVR enabled.",
      "inputs": [
        {
          "url": "rtmp://stream.example.com/live/primary-key",
          "priority": 0,
          "net": {
            "reconnect": true,
            "reconnect_delay_sec": 3,
            "reconnect_max_delay_sec": 60
          }
        },
        {
          "url": "rtmp://backup.example.com/live/backup-key",
          "priority": 1,
          "net": {
            "reconnect": true,
            "reconnect_delay_sec": 3,
            "reconnect_max_delay_sec": 60
          }
        }
      ],
      "transcoder": {
        "video": {
          "copy": false,
          "profiles": [
            {
              "width": 1920,
              "height": 1080,
              "bitrate": 4000,
              "max_bitrate": 5000,
              "framerate": 30,
              "keyframe_interval": 2,
              "codec": "h264",
              "preset": "fast",
              "profile": "high",
              "level": "4.0"
            },
            {
              "width": 1280,
              "height": 720,
              "bitrate": 2000,
              "max_bitrate": 2500,
              "framerate": 30,
              "keyframe_interval": 2,
              "codec": "h264",
              "preset": "fast"
            },
            {
              "width": 854,
              "height": 480,
              "bitrate": 800,
              "max_bitrate": 1000,
              "framerate": 25,
              "keyframe_interval": 2,
              "codec": "h264",
              "preset": "fast"
            }
          ]
        },
        "audio": {
          "copy": false,
          "codec": "aac",
          "bitrate": 128,
          "sample_rate": 44100,
          "channels": 2
        },
        "global": {
          "hw_accel": "nvenc"
        }
      },
      "protocols": {
        "hls": true,
        "dash": true,
        "rtsp": true,
        "rtmp": true,
        "srt": false
      },
      "dvr": {
        "enabled": true,
        "segment_duration": 6,
        "retention_sec": 86400,
        "storage_path": "/out/dvr",
        "max_size_gb": 10
      },
      "status": "stopped",
      "disabled": false
    },
    "udp-passthrough": {
      "code": "udp-passthrough",
      "name": "UDP MPEG-TS \u2014 Passthrough",
      "description": "Ingests multicast or unicast UDP MPEG-TS. No transcoding. Suitable for broadcast contribution links.",
      "inputs": [
        {
          "url": "udp://239.1.1.1:5000",
          "priority": 0
        },
        {
          "url": "udp://10.0.0.50:5001",
          "priority": 1,
          "description": "Unicast backup from encoder"
        }
      ],
      "protocols": {
        "hls": true,
        "dash": false,
        "rtsp": true,
        "rtmp": false,
        "srt": false
      },
      "status": "stopped",
      "disabled": false
    },
    "hls-pull-restream": {
      "code": "hls-pull-restream",
      "name": "HLS Pull \u2014 Transcode + Push to Platforms",
      "description": "Pulls a remote HLS stream, transcodes to H.264, and simultaneously re-streams to YouTube, Facebook, and Twitch.",
      "inputs": [
        {
          "url": "https://live.example.com/event/playlist.m3u8",
          "priority": 0,
          "net": {
            "reconnect": true,
            "reconnect_delay_sec": 5,
            "reconnect_max_delay_sec": 120
          }
        }
      ],
      "transcoder": {
        "video": {
          "copy": false,
          "profiles": [
            {
              "width": 1920,
              "height": 1080,
              "bitrate": 6000,
              "framerate": 30,
              "keyframe_interval": 2,
              "codec": "h264",
              "preset": "veryfast"
            }
          ]
        },
        "audio": {
          "copy": false,
          "codec": "aac",
          "bitrate": 160,
          "channels": 2
        },
        "global": {
          "hw_accel": "none"
        }
      },
      "protocols": {
        "hls": true,
        "dash": false,
        "rtsp": false,
        "rtmp": false,
        "srt": false
      },
      "push": [
        {
          "url": "rtmp://a.rtmp.youtube.com/live2/xxxx-xxxx-xxxx-xxxx",
          "enabled": true,
          "comment": "YouTube Live",
          "timeout_sec": 10,
          "retry_timeout_sec": 30
        },
        {
          "url": "rtmps://live-api-s.facebook.com:443/rtmp/xxxx-xxxx",
          "enabled": false,
          "comment": "Facebook Live (disabled until key is configured)"
        },
        {
          "url": "rtmp://live.twitch.tv/app/live_xxxx_xxxxxxxxxxxxxxxxxxxx",
          "enabled": false,
          "comment": "Twitch"
        }
      ],
      "status": "stopped",
      "disabled": false
    },
    "rtsp-camera": {
      "code": "rtsp-camera",
      "name": "RTSP IP Camera \u2014 Video Copy + Audio Transcode",
      "description": "Ingests H.264 from an IP camera over RTSP. Copies video as-is, re-encodes audio to AAC. Serves HLS.",
      "inputs": [
        {
          "url": "rtsp://admin:password@192.168.1.100:554/stream/main",
          "priority": 0,
          "net": {
            "reconnect": true,
            "reconnect_delay_sec": 5,
            "reconnect_max_delay_sec": 60,
            "connect_timeout_sec": 10,
            "read_timeout_sec": 30
          }
        },
        {
          "url": "rtsp://admin:password@192.168.1.100:554/stream/sub",
          "priority": 1,
          "description": "Sub-stream fallback (lower resolution)"
        }
      ],
      "transcoder": {
        "video": {
          "copy": true
        },
        "audio": {
          "copy": false,
          "codec": "aac",
          "bitrate": 64,
          "channels": 1
        },
        "global": {
          "hw_accel": "none"
        }
      },
      "protocols": {
        "hls": true,
        "dash": false,
        "rtsp": true,
        "rtmp": false,
        "srt": false
      },
      "dvr": {
        "enabled": true,
        "segment_duration": 10,
        "retention_sec": 604800,
        "storage_path": "/out/dvr",
        "max_size_gb": 50
      },
      "status": "stopped",
      "disabled": false
    },
    "file-loop-test": {
      "code": "file-loop-test",
      "name": "File Loop \u2014 Testing / Demo",
      "description": "Loops a local MPEG-TS file at real-time pace. Useful for load testing the publisher or demoing the server without a real encoder.",
      "inputs": [
        {
          "url": "file:///samples/big_buck_bunny_720p.ts?loop=true",
          "priority": 0
        }
      ],
      "transcoder": {
        "video": {
          "copy": false,
          "profiles": [
            {
              "width": 1280,
              "height": 720,
              "bitrate": 2000,
              "framerate": 30,
              "keyframe_interval": 2,
              "codec": "h264",
              "preset": "ultrafast"
            },
            {
              "width": 640,
              "height": 360,
              "bitrate": 600,
              "framerate": 30,
              "keyframe_interval": 2,
              "codec": "h264",
              "preset": "ultrafast"
            }
          ]
        },
        "audio": {
          "copy": true
        },
        "global": {
          "hw_accel": "none"
        }
      },
      "protocols": {
        "hls": true,
        "dash": true,
        "rtsp": false,
        "rtmp": false,
        "srt": false
      },
      "status": "stopped",
      "disabled": false
    },
    "s3-vod-loop": {
      "code": "s3-vod-loop",
      "name": "S3 Object Loop \u2014 VOD-as-Live",
      "description": "Streams a video file from S3 (or S3-compatible storage like MinIO / Cloudflare R2) in a loop to simulate a 24/7 live channel.",
      "inputs": [
        {
          "url": "s3://my-bucket/content/promo.ts?region=ap-southeast-1&loop=true",
          "priority": 0,
          "auth": {
            "username": "ACCESS_KEY_ID",
            "password": "SECRET_ACCESS_KEY"
          }
        },
        {
          "url": "s3://my-bucket/content/fallback.ts?region=ap-southeast-1&loop=true",
          "priority": 1,
          "auth": {
            "username": "ACCESS_KEY_ID",
            "password": "SECRET_ACCESS_KEY"
          }
        }
      ],
      "protocols": {
        "hls": true,
        "dash": false,
        "rtsp": false,
        "rtmp": false,
        "srt": false
      },
      "status": "stopped",
      "disabled": false
    },
    "srt-push-ingest": {
      "code": "srt-push-ingest",
      "name": "SRT Push Ingest",
      "description": "Low-latency contribution over SRT. External encoder pushes to :9999 with streamid=live/srt-push-ingest.",
      "inputs": [
        {
          "url": "srt://0.0.0.0:9999?streamid=live/srt-push-ingest",
          "priority": 0
        }
      ],
      "transcoder": {
        "video": {
          "copy": false,
          "profiles": [
            {
              "width": 1920,
              "height": 1080,
              "bitrate": 4000,
              "framerate": 30,
              "keyframe_interval": 2,
              "codec": "h264",
              "preset": "fast"
            }
          ]
        },
        "audio": {
          "copy": false,
          "codec": "aac",
          "bitrate": 128,
          "channels": 2
        },
        "global": {
          "hw_accel": "none"
        }
      },
      "protocols": {
        "hls": true,
        "dash": true,
        "rtsp": false,
        "rtmp": false,
        "srt": false
      },
      "status": "stopped",
      "disabled": false
    },
    "disabled-example": {
      "code": "disabled-example",
      "name": "Disabled Stream Example",
      "description": "A fully configured stream that is administratively disabled. The server will not start this stream on bootstrap.",
      "disabled": true,
      "inputs": [
        {
          "url": "rtmp://encoder.example.com/live/disabled-key",
          "priority": 0
        }
      ],
      "protocols": {
        "hls": true,
        "dash": false,
        "rtsp": false,
        "rtmp": false,
        "srt": false
      },
      "status": "stopped"
    }
  },
  "recordings": {},
  "hooks": {
    "webhook-lifecycle": {
      "id": "webhook-lifecycle",
      "name": "Lifecycle webhook",
      "type": "http",
      "target": "https://hooks.example.com/open-streamer",
      "secret": "replace-with-your-hmac-secret",
      "event_types": [
        "stream.started",
        "stream.stopped",
        "input.failover",
        "transcoder.error"
      ],
      "enabled": false,
      "max_retries": 3,
      "timeout_sec": 10
    },
    "kafka-all-events": {
      "id": "kafka-all-events",
      "name": "Kafka \u2014 all events",
      "type": "kafka",
      "target": "open-streamer-events",
      "event_types": [],
      "enabled": false
    }
  },
  "global": {
    "server": {
      "http_addr": ":8080",
      "cors": {
        "enabled": true,
        "allowed_origins": ["*"],
        "allowed_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
        "allow_credentials": false,
        "max_age": 600
      }
    },
    "listeners": {
      "rtmp": {
        "enabled": true,
        "listen_host": "0.0.0.0",
        "port": 1935
      },
      "rtsp": {
        "enabled": true,
        "listen_host": "0.0.0.0",
        "port": 8554,
        "transport": "tcp"
      },
      "srt": {
        "enabled": true,
        "listen_host": "0.0.0.0",
        "port": 9999,
        "latency_ms": 120
      }
    },
    "ingestor": {
      "hls_max_segment_buffer": 8
    },
    "buffer": {
      "capacity": 1000
    },
    "transcoder": {
      "max_workers": 4,
      "ffmpeg_path": "ffmpeg",
      "max_restarts": 5
    },
    "publisher": {
      "hls": {
        "dir": "/out/hls",
        "live_ephemeral": true,
        "live_segment_sec": 4,
        "live_window": 6,
        "live_history": 4
      },
      "dash": {
        "dir": "/out/dash",
        "live_ephemeral": true,
        "live_segment_sec": 4,
        "live_window": 6,
        "live_history": 4
      }
    },
    "manager": {
      "input_packet_timeout_sec": 30
    },
    "hooks": {
      "worker_count": 4
    },
    "log": {
      "level": "info",
      "format": "json"
    }
  }
}